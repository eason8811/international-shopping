<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="shopping.international.infrastructure.dao.customerservice.AfterSalesReshipItemMapper">

    <insert id="batchInsert">
        INSERT INTO aftersales_reship_item (reship_id, order_item_id, sku_id, quantity)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.reshipId}, #{item.orderItemId}, #{item.skuId}, #{item.quantity})
        </foreach>
    </insert>
</mapper>
